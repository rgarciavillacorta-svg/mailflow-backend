{
  "name": "mailflow-backend",
  "version": "1.0.0",
  "description": "MailFlow — Backend de Email Marketing con Resend, pixel tracking y automatización",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "cron": "node -e \"require('http').request({hostname:'localhost',port:3001,path:'/api/automation/process',method:'POST'},r=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>console.log('[CRON]',d))}).end()\""
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
